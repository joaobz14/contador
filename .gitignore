# Segredos e credenciais (NUNCA versionar)
credenciais.json
credenciais_shopee.json
link_autorizacao.txt
link_autorizacao_shopee.txt
bot_config.json

# Arquivos por conta (contas/{nome}/)
contas/*/credenciais.json
contas/*/estado_grupos.json
contas/*/itens_cache.json
contas/*/envios_cache.json

# Estado e cache gerados em tempo de execucao
estado_grupos.json
estado_shopee.json
itens_cache.json
envios_cache.json
awb_cache_shopee.json
config.json
bot.log
shopee_tempos.log
ml_tempos.log
separador.log
historico_impressao.json
*.tmp
*.bak
*.corrupto

# Bytecode / cache do Python
__pycache__/
*.py[cod]
*.pyo

# Ambientes virtuais
.venv/
venv/
env/

# Sistema operacional / editores
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/worktrees/

# Obsidian: estado local da interface e cache da maquina
obsidian/.obsidian/workspace.json
obsidian/.obsidian/workspace-mobile.json
obsidian/.obsidian/cache/

# graphify: versiona artefatos compartilhaveis; ignora cache e arquivos da maquina
graphify-out/cache/
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_labels.json
*.lock

# Logs de runtime do monitor de APIs
api-monitor/logs/
api-monitor/fetched/

# Saidas geradas do monitor de APIs (locais, recriadas a cada run) - versionar so
# a infra (prompt/scripts/README), nao os baselines/relatorios (evita a churn que
# fazia todo git pull colidir na maquina de operacao)
api-monitor/relatorios/*
!api-monitor/relatorios/.gitkeep
api-monitor/snapshots/*.md
!api-monitor/snapshots/README.md
