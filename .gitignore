separador.log
*.tmp
*.bak

# Bytecode / cache do Python
__pycache__/
*.py[cod]
*.pyo

# Ambientes virtuais
.venv/
venv/
env/

# Sistema operacional / editores
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/worktrees/

# graphify: versiona artefatos compartilhaveis; ignora cache e arquivos da maquina
graphify-out/cache/
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_labels.json
*.lock
